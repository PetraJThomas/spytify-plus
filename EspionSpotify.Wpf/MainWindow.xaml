<Window x:Class="EspionSpotify.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:l="clr-namespace:EspionSpotify.Wpf"
        ui:WindowHelper.UseModernWindowStyle="True"
        Icon="Assets/spytify-icon.png" Opacity="0"
        Title="Spytify" Height="640" Width="1000" MinHeight="480" MinWidth="860">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.35">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <l:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#16FFFFFF" />
            <Setter Property="BorderBrush" Value="#22FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1ED760" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Width" Value="150" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#CCCCCC" />
        </Style>

        <Style x:Key="Row" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Margin" Value="0,6,0,6" />
        </Style>
    </Window.Resources>

    <ui:NavigationView x:Name="Nav"
                       PaneDisplayMode="Left"
                       IsBackButtonVisible="Collapsed"
                       IsSettingsVisible="False"
                       OpenPaneLength="180"
                       SelectionChanged="Nav_SelectionChanged"
                       ItemInvoked="Nav_ItemInvoked">
        <ui:NavigationView.PaneFooter>
            <!-- Two logos cross-faded by pane state: the wide wordmark when expanded,
                 the square icon when collapsed (see UpdateLogo in code-behind). -->
            <Grid Height="34" Margin="0,12,0,16">
                <Image x:Name="LogoFull" Source="Assets/spytify-logo.png" Stretch="Uniform"
                       Width="170" HorizontalAlignment="Left" VerticalAlignment="Center"
                       Margin="14,0,12,0" Opacity="1" />
                <Image x:Name="LogoIcon" Source="Assets/spytify-icon.png" Stretch="Uniform"
                       Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Opacity="0" />
            </Grid>
        </ui:NavigationView.PaneFooter>
        <ui:NavigationView.MenuItems>
            <ui:NavigationViewItem Content="{l:Tr tabRecord}" Tag="record" IsSelected="True">
                <ui:NavigationViewItem.Icon>
                    <ui:FontIcon Glyph="&#xE7C8;" />
                </ui:NavigationViewItem.Icon>
            </ui:NavigationViewItem>
            <ui:NavigationViewItem Content="{l:Tr tabSettings}" Tag="settings">
                <ui:NavigationViewItem.Icon>
                    <ui:FontIcon Glyph="&#xE713;" />
                </ui:NavigationViewItem.Icon>
            </ui:NavigationViewItem>
            <ui:NavigationViewItem Content="{l:Tr tabAdvanced}" Tag="advanced">
                <ui:NavigationViewItem.Icon>
                    <ui:FontIcon Glyph="&#xE9E9;" />
                </ui:NavigationViewItem.Icon>
            </ui:NavigationViewItem>
        </ui:NavigationView.MenuItems>

        <Grid Margin="24,16,24,20">

            <!-- ===================== RECORD ===================== -->
            <Grid x:Name="RecordPanel">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- now playing + start/stop -->
                <Border Grid.Row="0" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Ellipse Grid.Column="0" Width="14" Height="14" Margin="0,0,14,0"
                                 VerticalAlignment="Center" Fill="{Binding StatusBrush}"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform />
                            </Ellipse.RenderTransform>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="PulseSb">
                                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                         To="1.9" Duration="0:0:0.85" />
                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                         To="1.9" Duration="0:0:0.85" />
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1" To="0.35" Duration="0:0:0.85" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="PulseSb" />
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding NowPlaying}" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{Binding StatusBrush}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="Now playing" FontSize="12" Foreground="#888" />
                        </StackPanel>

                        <TextBlock Grid.Column="2" Text="{Binding RecordedTime}" FontSize="22"
                                   FontFamily="Consolas" Foreground="#1ED760"
                                   VerticalAlignment="Center" Margin="0,0,20,0" />

                        <Button Grid.Column="3" Content="{Binding StartStopLabel}"
                                Command="{Binding StartStopCommand}"
                                ui:ControlHelper.CornerRadius="6"
                                Padding="20,8" FontWeight="SemiBold"
                                Background="#1ED760" Foreground="#0A0A0A" BorderThickness="0"
                                RenderTransformOrigin="0.5,0.5">
                            <Button.RenderTransform>
                                <ScaleTransform />
                            </Button.RenderTransform>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.04" Duration="0:0:0.12" />
                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.04" Duration="0:0:0.12" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.12" />
                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.12" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- console: read-only RichTextBox so text is freely selectable (drag / Shift+arrows /
                     Ctrl+A) and copyable (Ctrl+C). Lines are appended in code-behind. -->
                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                    <RichTextBox x:Name="LogBox" IsReadOnly="True" IsDocumentEnabled="True"
                                 Background="#181818" Foreground="#B3B3B3" BorderThickness="0"
                                 FontFamily="Consolas" Padding="8,6"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <RichTextBox.Resources>
                            <Style TargetType="Paragraph">
                                <Setter Property="Margin" Value="0" />
                            </Style>
                        </RichTextBox.Resources>
                    </RichTextBox>
                </Border>

                <!-- footer -->
                <Grid Grid.Row="2" Margin="2,2,2,0">
                    <TextBlock Text="{Binding DeviceName}" Foreground="#999" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Copy log" Command="{Binding CopyLogCommand}" Margin="0,0,8,0" />
                        <Button Content="Clear" Command="{Binding ClearLogCommand}" Margin="0,0,8,0" />
                        <Button Content="Open folder" Command="{Binding OpenOutputCommand}" />
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ===================== SETTINGS ===================== -->
            <ScrollViewer x:Name="SettingsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="OUTPUT" />
                            <StackPanel Style="{StaticResource Row}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{l:Tr lblPath}" />
                                <TextBox Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}" Width="430" />
                                <Button Content="Browse…" Command="{Binding BrowseOutputCommand}" Margin="8,0,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="AUDIO" />
                            <StackPanel Style="{StaticResource Row}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{l:Tr lblAudioDevice}" />
                                <ComboBox ItemsSource="{Binding Devices}" SelectedValuePath="Key"
                                          DisplayMemberPath="Value" SelectedValue="{Binding SelectedDeviceId, Mode=TwoWay}"
                                          Width="430" />
                            </StackPanel>
                            <StackPanel Style="{StaticResource Row}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{l:Tr lblFormat}" />
                                <ComboBox ItemsSource="{Binding Formats}" SelectedValuePath="Key"
                                          DisplayMemberPath="Value" SelectedValue="{Binding SelectedFormat, Mode=TwoWay}"
                                          Width="200" />
                            </StackPanel>
                            <StackPanel Style="{StaticResource Row}"
                                        Visibility="{Binding BitrateVisible, Converter={StaticResource BoolToVis}}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{l:Tr lblBitRate}" />
                                <ComboBox ItemsSource="{Binding Bitrates}" SelectedValuePath="Key"
                                          DisplayMemberPath="Value" SelectedValue="{Binding SelectedBitrate, Mode=TwoWay}"
                                          Width="280" />
                            </StackPanel>
                            <StackPanel Style="{StaticResource Row}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{l:Tr lblMinLength}" />
                                <Slider Minimum="0" Maximum="120" TickFrequency="5" IsSnapToTickEnabled="True"
                                        Value="{Binding MinLengthSeconds, Mode=TwoWay}" Width="260"
                                        VerticalAlignment="Center" />
                                <TextBlock Text="{Binding MinLengthDisplay}" Margin="12,0,0,0"
                                           VerticalAlignment="Center" Foreground="#CCC" />
                            </StackPanel>
                            <StackPanel Style="{StaticResource Row}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Device volume" />
                                <Slider Minimum="0" Maximum="100" Width="260" VerticalAlignment="Center"
                                        Value="{Binding Volume, Mode=TwoWay}" IsEnabled="{Binding VolumeEnabled}" />
                                <TextBlock Text="{Binding VolumePercent}" Margin="12,0,0,0"
                                           VerticalAlignment="Center" Foreground="#CCC" />
                            </StackPanel>
                            <StackPanel Style="{StaticResource Row}"
                                        Visibility="{Binding DriverButtonVisible, Converter={StaticResource BoolToVis}}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Virtual cable" />
                                <Button Content="{Binding DriverButtonText}" Command="{Binding InstallDriverCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}"
                            Visibility="{Binding SpotifyOptionsVisible, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="METADATA SOURCE" />
                            <StackPanel Style="{StaticResource Row}">
                                <RadioButton GroupName="api" Content="Last.fm" Margin="0,0,20,0"
                                             IsChecked="{Binding IsLastFmSelected, Mode=TwoWay}" />
                                <RadioButton GroupName="api" Content="Spotify API"
                                             IsChecked="{Binding IsSpotifySelected, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel Visibility="{Binding SpotifyCredentialsVisible, Converter={StaticResource BoolToVis}}"
                                        Margin="0,8,0,0">
                                <StackPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="{l:Tr lblClientId}" />
                                    <Grid Width="430">
                                        <TextBox Text="{Binding SpotifyClientId, UpdateSourceTrigger=LostFocus}"
                                                 Visibility="{Binding ShowClientId, Converter={StaticResource BoolToVis}}" />
                                        <TextBox Text="{Binding ClientIdMasked, Mode=OneWay}" IsReadOnly="True" Focusable="False"
                                                 Visibility="{Binding ShowClientId, Converter={StaticResource InverseBoolToVis}}" />
                                    </Grid>
                                    <ToggleButton IsChecked="{Binding ShowClientId, Mode=TwoWay}" Width="36" Margin="6,0,0,0"
                                                  ToolTip="Show / hide">
                                        <ui:FontIcon Glyph="&#xE7B3;" FontSize="14" />
                                    </ToggleButton>
                                </StackPanel>
                                <StackPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="{l:Tr lblSecretId}" />
                                    <Grid Width="430">
                                        <TextBox Text="{Binding SpotifySecretId, UpdateSourceTrigger=LostFocus}"
                                                 Visibility="{Binding ShowSecret, Converter={StaticResource BoolToVis}}" />
                                        <TextBox Text="{Binding SecretMasked, Mode=OneWay}" IsReadOnly="True" Focusable="False"
                                                 Visibility="{Binding ShowSecret, Converter={StaticResource InverseBoolToVis}}" />
                                    </Grid>
                                    <ToggleButton IsChecked="{Binding ShowSecret, Mode=TwoWay}" Width="36" Margin="6,0,0,0"
                                                  ToolTip="Show / hide">
                                        <ui:FontIcon Glyph="&#xE7B3;" FontSize="14" />
                                    </ToggleButton>
                                </StackPanel>
                                <StackPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="{l:Tr lblRedirectURL}" />
                                    <TextBox Text="{Binding SpotifyRedirectUrl, UpdateSourceTrigger=PropertyChanged}" Width="430" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="{l:Tr lblGeneral}" />
                            <StackPanel Style="{StaticResource Row}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{l:Tr lblLanguage}" />
                                <ComboBox ItemsSource="{Binding LanguageOptions}" SelectedValuePath="Key"
                                          DisplayMemberPath="Value" SelectedValue="{Binding SelectedLanguage, Mode=TwoWay}"
                                          Width="200" />
                            </StackPanel>
                            <ui:ToggleSwitch Header="{l:Tr lblMuteAds}" IsOn="{Binding MuteAds, Mode=TwoWay}" />
                            <ui:ToggleSwitch Header="{l:Tr lblMinimizeToSystemTray}" IsOn="{Binding MinimizeToTray, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ===================== ADVANCED ===================== -->
            <ScrollViewer x:Name="AdvancedPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="{l:Tr lblSpy}" />
                            <ui:ToggleSwitch Header="{l:Tr lblListenToSpotifyPlayback}" IsOn="{Binding ListenToPlayback, Mode=TwoWay}" />
                            <ui:ToggleSwitch Header="{l:Tr lblForceSpotifyToSkip}" IsOn="{Binding ForceSkip, Mode=TwoWay}" />
                            <ui:ToggleSwitch Header="{l:Tr lblRecordEverything}" IsOn="{Binding RecordEverything, Mode=TwoWay}" />
                            <CheckBox Content="{l:Tr lblRecordAds}" Margin="6,0,0,6"
                                      IsChecked="{Binding RecordAds, Mode=TwoWay}"
                                      Visibility="{Binding RecordAdsVisible, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="{l:Tr lblRecorder}" />
                            <ui:ToggleSwitch Header="{l:Tr lblAddFolders}" IsOn="{Binding AddFolders, Mode=TwoWay}" />
                            <ui:ToggleSwitch Header="{l:Tr lblAddSeparators}" IsOn="{Binding AddSeparators, Mode=TwoWay}" />
                            <ui:ToggleSwitch Header="{l:Tr lblCounterToFilePrefix}" IsOn="{Binding CounterToFilePrefix, Mode=TwoWay}" />
                            <ui:ToggleSwitch Header="{l:Tr lblAlbumTrackNumberToFilePrefix}" IsOn="{Binding AlbumTrackNumberPrefix, Mode=TwoWay}" />
                            <ui:ToggleSwitch Header="{l:Tr lblRecordOverRecordings}" IsOn="{Binding RecordOverRecordings, Mode=TwoWay}" />
                            <CheckBox Content="{l:Tr lblDuplicate}" Margin="6,0,0,6"
                                      IsChecked="{Binding DuplicateRecordings, Mode=TwoWay}"
                                      Visibility="{Binding DuplicateVisible, Converter={StaticResource BoolToVis}}" />

                            <Border Height="1" Background="#22FFFFFF" Margin="0,10,0,10" />

                            <StackPanel Style="{StaticResource Row}"
                                        ToolTip="Hold Ctrl while clicking − / + to change the number of digits">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{l:Tr lblRecordingNum}" />
                                <Button Content="−" Command="{Binding NumMinusCommand}" Width="34" />
                                <TextBox Text="{Binding RecordingNumber, UpdateSourceTrigger=LostFocus}"
                                         Width="80" Margin="6,0,6,0" TextAlignment="Center" />
                                <Button Content="+" Command="{Binding NumPlusCommand}" Width="34" />
                            </StackPanel>

                            <StackPanel Style="{StaticResource Row}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{l:Tr lblRecordingTimer}" />
                                <TextBox Text="{Binding RecordingTimerText, UpdateSourceTrigger=LostFocus}"
                                         Width="110" ui:ControlHelper.PlaceholderText="HH:MM:SS" />
                                <TextBlock Text="(blank = off)" Foreground="#888" VerticalAlignment="Center" Margin="10,0,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="{l:Tr lblID3}" />
                            <ui:ToggleSwitch Header="{l:Tr lblCounterToMediaTag}" IsOn="{Binding CounterToMediaTag, Mode=TwoWay}" />
                            <ui:ToggleSwitch Header="{l:Tr lblExtraTitleToSubtitle}" IsOn="{Binding ExtraTitleToSubtitle, Mode=TwoWay}" />
                            <ui:ToggleSwitch Header="{l:Tr lblUpdateRecordingsID3Tags}" IsOn="{Binding UpdateId3Tags, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

        </Grid>
    </ui:NavigationView>
</Window>
