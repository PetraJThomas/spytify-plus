<Window x:Class="EspionSpotify.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:l="clr-namespace:EspionSpotify.Wpf"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.IsIconVisible="True"
        Icon="Assets/spytify.ico" Opacity="0"
        Title="Spytify+" Height="640" Width="1000" MinHeight="480" MinWidth="860">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.35">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <l:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#16FFFFFF" />
            <Setter Property="BorderBrush" Value="#22FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="20,24,20,24" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#1ED760" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <!-- Muted sub-heading for grouping controls inside a card. -->
        <Style x:Key="SubHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#9A9A9A" />
            <Setter Property="Margin" Value="0,2,0,8" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="MinWidth" Value="155" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#D8D8D8" />
            <Setter Property="FontSize" Value="16" />
        </Style>

        <Style x:Key="Row" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Margin" Value="0,9,0,9" />
        </Style>

        <!-- Left-aligned icon for buttons that pair a glyph with a label. -->
        <Style x:Key="BtnIcon" TargetType="ui:FontIcon">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Logos as resolution-independent vector (converted from the SVG source) so they
             render crisp at any size/DPI instead of down-sampling a large PNG. -->
        <DrawingImage x:Key="LogoIconDrawing">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#1FD65F">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="214.62,214.62" RadiusX="214.62" RadiusY="214.62" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#F7FCF9" Geometry="F1 M342.77,184.34c-77.85-36.92-168-42.23-250.74-21.66-13.07,3.25-24.57.18-29-13.25-3.55-10.77,1.97-24.42,16.22-27.85,93.98-22.63,196.48-17.2,283.38,24.88,10.6,5.13,17.06,10.42,19.22,19.46,2.48,10.39-3.32,19.09-10.76,23.45-11.01,6.45-16.92.39-28.33-5.02Z" />
                    <GeometryDrawing Brush="#F7FCF9" Geometry="F1 M148.5,192.15c-36.1,31.26-42.25,81.65-19.98,122.66-35.14-13.7-61.35-39.46-81.05-68.62,30.55-30.43,60.91-48.86,101.02-54.04Z" />
                    <GeometryDrawing Brush="#F7FCF9" Geometry="F1 M286.52,328.73c29.58-31.36,34.73-75.96,16.51-114.11,30.44,13.56,48.61,37.32,71.48,65.24-27.05,20.98-54.15,41.13-87.99,48.86Z" />
                    <GeometryDrawing Brush="#BEFDD4" Geometry="F1 M303.03,214.62c12.65,9.26,14.75,27.3,15.28,42.28.88,25.21-7.57,60.14-31.79,71.83-53.39,12.19-106.72,6.07-157.99-13.92-13.9-9.21-16.93-29.68-17.65-45.62-1.24-27.7,9.71-66.45,37.62-77.03,52.61-6.79,105.88.8,154.53,22.47Z" />
                    <GeometryDrawing Brush="#69E493">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="214.62,260.06" RadiusX="57.82" RadiusY="57.82" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#20793E">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="213.41,261.5" RadiusX="22.1" RadiusY="22.1" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>

