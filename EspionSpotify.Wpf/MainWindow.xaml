                    <GeometryDrawing Brush="#1FD65F" Geometry="F1 M1188.68,328.73c-3.82,0-7.4-.29-10.72-.88-3.33-.59-6.08-1.33-8.24-2.23l6.79-22.5c3.54,1.08,6.73,1.67,9.59,1.77,2.85.09,5.33-.57,7.43-1.98,2.1-1.42,3.81-3.82,5.13-7.22l1.77-4.6-39-111.82h31.71l22.51,79.83h1.13l22.72-79.83h31.92l-42.25,120.45c-2.03,5.85-4.78,10.96-8.24,15.32-3.47,4.36-7.84,7.74-13.13,10.12-5.29,2.38-11.65,3.57-19.11,3.57Z" />
                    <GeometryDrawing Brush="#1FD65F" Geometry="F1 M1314.46,248.29v-36.77h145.43v36.77h-145.43ZM1368.79,302.62v-145.43h36.77v145.43h-36.77Z" />
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>
    </Window.Resources>

    <ui:NavigationView x:Name="Nav"
                       PaneDisplayMode="Left"
                       IsBackButtonVisible="Collapsed"
                       IsSettingsVisible="False"
                       OpenPaneLength="180"
                       SelectionChanged="Nav_SelectionChanged"
                       ItemInvoked="Nav_ItemInvoked">
        <ui:NavigationView.PaneFooter>
            <!-- Two logos cross-faded by pane state: the wide wordmark when expanded,
                 the square icon when collapsed (see UpdateLogo in code-behind). -->
            <Grid Height="34" Margin="0,12,0,16">
                <Image x:Name="LogoFull" Source="{StaticResource LogoFullDrawing}" Stretch="Uniform"
                       Width="170" HorizontalAlignment="Left" VerticalAlignment="Center"
                       Margin="14,0,12,0" Opacity="1" />
                <Image x:Name="LogoIcon" Source="{StaticResource LogoIconDrawing}" Stretch="Uniform"
                       Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Opacity="0" />
            </Grid>
        </ui:NavigationView.PaneFooter>
        <ui:NavigationView.MenuItems>
            <ui:NavigationViewItem Content="{l:Tr tabRecord}" Tag="record" IsSelected="True">
                <ui:NavigationViewItem.Icon>
                    <ui:FontIcon Glyph="&#xE7C8;" />
                </ui:NavigationViewItem.Icon>
            </ui:NavigationViewItem>
            <ui:NavigationViewItem Content="{l:Tr tabSettings}" Tag="settings">
                <ui:NavigationViewItem.Icon>
                    <ui:FontIcon Glyph="&#xE713;" />
                </ui:NavigationViewItem.Icon>
            </ui:NavigationViewItem>
            <ui:NavigationViewItem Content="{l:Tr tabAdvanced}" Tag="advanced">
                <ui:NavigationViewItem.Icon>
                    <ui:FontIcon Glyph="&#xE9E9;" />
                </ui:NavigationViewItem.Icon>
            </ui:NavigationViewItem>
            <ui:NavigationViewItem Content="{l:Tr tabAnalyze}" Tag="analyze">
                <ui:NavigationViewItem.Icon>
                    <ui:FontIcon Glyph="&#xE9D9;" />
                </ui:NavigationViewItem.Icon>
            </ui:NavigationViewItem>
        </ui:NavigationView.MenuItems>

        <Grid Margin="24,16,24,20">

            <!-- ===================== RECORD ===================== -->
            <Grid x:Name="RecordPanel">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- now playing + start/stop: a mini Spotify-style player card -->
                <Border Grid.Row="0" Style="{StaticResource Card}" Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Album art of the current track. A placeholder note shows through until the
                             cover loads (AlbumArt is null when idle / during ads / before the API fills it). -->
                        <Grid Grid.Column="0" Width="68" Height="68" Margin="0,0,16,0">
                            <Grid.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="14" ShadowDepth="0" Opacity="0.55" />
                            </Grid.Effect>
                            <Border CornerRadius="6" Background="#282828">
                                <ui:FontIcon Glyph="&#xEC4F;" FontSize="26" Foreground="#5A5A5A"
                                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Border CornerRadius="6">
                                <Border.Background>
                                    <ImageBrush ImageSource="{Binding AlbumArt}" Stretch="UniformToFill" />
                                </Border.Background>
                            </Border>
                        </Grid>

                        <Ellipse Grid.Column="1" Width="14" Height="14" Margin="0,0,14,0"
                                 VerticalAlignment="Center" Fill="{Binding StatusBrush}"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform />
                            </Ellipse.RenderTransform>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="PulseSb">
                                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                         To="1.9" Duration="0:0:0.85" />
                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                         To="1.9" Duration="0:0:0.85" />
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1" To="0.35" Duration="0:0:0.85" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="PulseSb" />
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding NowPlaying}" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{Binding StatusBrush}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{l:Tr lblNowPlaying}" FontSize="12" Foreground="#888" />
                        </StackPanel>

                        <TextBlock Grid.Column="3" Text="{Binding RecordedTime}" FontSize="22"
                                   FontFamily="Consolas" Foreground="#1ED760"
                                   VerticalAlignment="Center" Margin="0,0,20,0" />

                        <Button Grid.Column="4"
                                Command="{Binding StartStopCommand}"
                                ui:ControlHelper.CornerRadius="6"
                                Padding="20,8" FontWeight="SemiBold"
                                Background="#1ED760" Foreground="#0A0A0A" BorderThickness="0">
                            <StackPanel Orientation="Horizontal">
                                <Grid Width="11" Height="11" Margin="0,0,9,0" VerticalAlignment="Center">
                                    <Ellipse Fill="#0A0A0A"
                                             Visibility="{Binding IsRecording, Converter={StaticResource InverseBoolToVis}}" />
                                    <Rectangle Fill="#0A0A0A" RadiusX="2" RadiusY="2"
                                               Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}" />
                                </Grid>
                                <TextBlock Text="{Binding StartStopLabel}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- console: read-only RichTextBox so text is freely selectable (drag / Shift+arrows /
                     Ctrl+A) and copyable (Ctrl+C). Lines are appended in code-behind. -->
                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                    <RichTextBox x:Name="LogBox" IsReadOnly="True" IsDocumentEnabled="True"
                                 Background="#181818" Foreground="#B3B3B3" BorderThickness="0"
                                 FontFamily="Consolas" Padding="8,6"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <RichTextBox.Resources>
                            <Style TargetType="Paragraph">
                                <Setter Property="Margin" Value="0" />
                            </Style>
                        </RichTextBox.Resources>
                    </RichTextBox>
                </Border>

                <!-- footer -->
                <Grid Grid.Row="2" Margin="2,2,2,0">
                    <TextBlock Text="{Binding DeviceName}" Foreground="#999" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding CopyLogCommand}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Style="{StaticResource BtnIcon}" Glyph="&#xE8C8;" FontSize="13" />
                                <TextBlock Text="{l:Tr lblCopyLog}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ClearLogCommand}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Style="{StaticResource BtnIcon}" Glyph="&#xE894;" FontSize="13" />
                                <TextBlock Text="{l:Tr lblClearLog}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding OpenOutputCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Style="{StaticResource BtnIcon}" Glyph="&#xE8B7;" FontSize="13" />
                                <TextBlock Text="{l:Tr lblOpenFolder}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ===================== SETTINGS ===================== -->
            <ScrollViewer x:Name="SettingsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Resources>
                    <!-- Buttons on this page match the field/combo height (32). -->
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Height" Value="32" />
                    </Style>
                </ScrollViewer.Resources>
                <StackPanel>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="{l:Tr lblOutput}" />
                            <StackPanel Style="{StaticResource Row}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{l:Tr lblPath}" />
                                <TextBox Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}" Width="430" />
                                <Button Command="{Binding BrowseOutputCommand}" Margin="8,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:FontIcon Style="{StaticResource BtnIcon}" Glyph="&#xE8B7;" />
                                        <TextBlock Text="{l:Tr lblBrowse}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="{l:Tr lblAudio}" />
                            <StackPanel Style="{StaticResource Row}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{l:Tr lblAudioDevice}" />
                                <ComboBox ItemsSource="{Binding Devices}" SelectedValuePath="Key"
                                          DisplayMemberPath="Value" SelectedValue="{Binding SelectedDeviceId, Mode=TwoWay}"
                                          Width="430" />
                            </StackPanel>
                            <StackPanel Style="{StaticResource Row}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{l:Tr lblFormat}" />
                                <ComboBox ItemsSource="{Binding Formats}" SelectedValuePath="Key"
                                          DisplayMemberPath="Value" SelectedValue="{Binding SelectedFormat, Mode=TwoWay}"
                                          Width="200" />
                            </StackPanel>
                            <StackPanel Style="{StaticResource Row}"
                                        Visibility="{Binding BitrateVisible, Converter={StaticResource BoolToVis}}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{l:Tr lblBitRate}" />
                                <ComboBox ItemsSource="{Binding Bitrates}" SelectedValuePath="Key"
                                          DisplayMemberPath="Value" SelectedValue="{Binding SelectedBitrate, Mode=TwoWay}"
                                          Width="280" />
                            </StackPanel>
                            <StackPanel Style="{StaticResource Row}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{l:Tr lblMinLength}" />
                                <Slider Minimum="0" Maximum="120" TickFrequency="5" IsSnapToTickEnabled="True"
                                        Value="{Binding MinLengthSeconds, Mode=TwoWay}" Width="260"
                                        VerticalAlignment="Center" />
                                <TextBlock Text="{Binding MinLengthDisplay}" Margin="12,0,0,0"
                                           VerticalAlignment="Center" Foreground="#CCC" />
                            </StackPanel>
                            <StackPanel Style="{StaticResource Row}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{l:Tr lblDeviceVolume}" />
                                <Slider Minimum="0" Maximum="100" Width="260" VerticalAlignment="Center"
                                        Value="{Binding Volume, Mode=TwoWay}" IsEnabled="{Binding VolumeEnabled}" />
                                <TextBlock Text="{Binding VolumePercent}" Margin="12,0,0,0"
                                           VerticalAlignment="Center" Foreground="#CCC" />
                            </StackPanel>
                            <StackPanel Style="{StaticResource Row}"
                                        Visibility="{Binding DriverButtonVisible, Converter={StaticResource BoolToVis}}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{l:Tr lblVirtualCable}" />
                                <Button Command="{Binding InstallDriverCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:FontIcon Style="{StaticResource BtnIcon}" Glyph="&#xE72C;" />
                                        <TextBlock Text="{Binding DriverButtonText}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}"
                            Visibility="{Binding SpotifyOptionsVisible, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="{l:Tr lblMetadataSource}" />
                            <StackPanel Style="{StaticResource Row}">
                                <RadioButton GroupName="api" Content="Last.fm" Margin="0,0,20,0"
                                             IsChecked="{Binding IsLastFmSelected, Mode=TwoWay}" />
                                <RadioButton GroupName="api" Content="Spotify API"
                                             IsChecked="{Binding IsSpotifySelected, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel Visibility="{Binding SpotifyCredentialsVisible, Converter={StaticResource BoolToVis}}"
                                        Margin="0,8,0,0">
                                <StackPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="{l:Tr lblClientId}" />
                                    <Grid Width="430">
                                        <TextBox Text="{Binding SpotifyClientId, UpdateSourceTrigger=LostFocus}"
                                                 Visibility="{Binding ShowClientId, Converter={StaticResource BoolToVis}}" />
                                        <TextBox Text="{Binding ClientIdMasked, Mode=OneWay}" IsReadOnly="True" Focusable="False"
                                                 Visibility="{Binding ShowClientId, Converter={StaticResource InverseBoolToVis}}" />
                                    </Grid>
                                    <ToggleButton Style="{StaticResource IconToggleButton}" IsChecked="{Binding ShowClientId, Mode=TwoWay}"
                                                  Width="36" Margin="6,0,0,0" ToolTip="{l:Tr lblShowHide}">
                                        <ui:FontIcon Glyph="&#xE7B3;" FontSize="14" />
                                    </ToggleButton>
                                </StackPanel>
                                <StackPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="{l:Tr lblSecretId}" />
                                    <Grid Width="430">
                                        <TextBox Text="{Binding SpotifySecretId, UpdateSourceTrigger=LostFocus}"
                                                 Visibility="{Binding ShowSecret, Converter={StaticResource BoolToVis}}" />
                                        <TextBox Text="{Binding SecretMasked, Mode=OneWay}" IsReadOnly="True" Focusable="False"
                                                 Visibility="{Binding ShowSecret, Converter={StaticResource InverseBoolToVis}}" />
                                    </Grid>
                                    <ToggleButton Style="{StaticResource IconToggleButton}" IsChecked="{Binding ShowSecret, Mode=TwoWay}"
                                                  Width="36" Margin="6,0,0,0" ToolTip="{l:Tr lblShowHide}">
                                        <ui:FontIcon Glyph="&#xE7B3;" FontSize="14" />
                                    </ToggleButton>
                                </StackPanel>
                                <StackPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="{l:Tr lblRedirectURL}" />
                                    <TextBox Text="{Binding SpotifyRedirectUrl, UpdateSourceTrigger=PropertyChanged}" Width="430" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,56,0,2">
                                    <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center"
                                             Fill="{Binding SpotifyConnectionBrush}" />
                                    <TextBlock Text="{Binding SpotifyConnectionStatus}" VerticalAlignment="Center"
                                               Margin="0,0,16,0" Foreground="#D8D8D8" />
                                    <Button Click="ConnectSpotify_Click"
                                            IsEnabled="{Binding CanConnectSpotify}" Padding="16,6" Cursor="Hand"
                                            Background="{StaticResource SpotifyGreenBrush}" Foreground="#000000" BorderThickness="0">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:FontIcon Style="{StaticResource BtnIcon}" Glyph="&#xE71B;" Foreground="#000000" />
                                            <TextBlock Text="{l:Tr lblConnectToSpotify}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="{l:Tr lblGeneral}" />
                            <ui:ToggleSwitch Header="{l:Tr lblMuteAds}" IsOn="{Binding MuteAds, Mode=TwoWay}" />
                            <ui:ToggleSwitch Header="{l:Tr lblMinimizeToSystemTray}" IsOn="{Binding MinimizeToTray, Mode=TwoWay}" />
                            <StackPanel Style="{StaticResource Row}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{l:Tr lblLanguage}" />
                                <ComboBox ItemsSource="{Binding LanguageOptions}" SelectedValuePath="Key"
                                          DisplayMemberPath="Value" SelectedValue="{Binding SelectedLanguage, Mode=TwoWay}"
                                          Width="200" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ===================== ADVANCED ===================== -->
            <ScrollViewer x:Name="AdvancedPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Resources>
                    <!-- Buttons on this page match the field/combo height (32). -->
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Height" Value="32" />
                    </Style>
                </ScrollViewer.Resources>
                <StackPanel>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="{l:Tr lblSpy}" />
                            <ui:ToggleSwitch Header="{l:Tr lblListenToSpotifyPlayback}" IsOn="{Binding ListenToPlayback, Mode=TwoWay}" />
                            <ui:ToggleSwitch Header="{l:Tr lblForceSpotifyToSkip}" IsOn="{Binding ForceSkip, Mode=TwoWay}" />
                            <ui:ToggleSwitch Header="{l:Tr lblRecordEverything}" IsOn="{Binding RecordEverything, Mode=TwoWay}" />
                            <CheckBox Content="{l:Tr lblRecordAds}"
                                      IsChecked="{Binding RecordAds, Mode=TwoWay}"
                                      Visibility="{Binding RecordAdsVisible, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </Border>

                    <!-- Everything about how the recorded song is tagged, named and filed. -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="{l:Tr lblMetadataOrganisation}" />

                            <ui:ToggleSwitch Header="{l:Tr lblPlaylistAsAlbum}" IsOn="{Binding PlaylistAsAlbum, Mode=TwoWay}"
                                             ToolTip="{l:Tr tipPlaylistAsAlbum}" />
                            <Border Height="1" Background="#18FFFFFF" Margin="0,10,0,12" />

                            <TextBlock Style="{StaticResource SubHeader}" Text="{l:Tr lblID3}" />
                            <ui:ToggleSwitch Header="{l:Tr lblCounterToMediaTag}" IsOn="{Binding CounterToMediaTag, Mode=TwoWay}" />
                            <ui:ToggleSwitch Header="{l:Tr lblExtraTitleToSubtitle}" IsOn="{Binding ExtraTitleToSubtitle, Mode=TwoWay}" />
                            <ui:ToggleSwitch Header="{l:Tr lblUpdateRecordingsID3Tags}" IsOn="{Binding UpdateId3Tags, Mode=TwoWay}" />

                            <Border Height="1" Background="#22FFFFFF" Margin="0,14,0,12" />

                            <TextBlock Style="{StaticResource SubHeader}" Text="{l:Tr lblFilesAndFolders}" />

                            <!-- Opt-in template override. When on it drives folder + file naming; the
                                 toggles below are greyed out because the template supersedes them. -->
                            <ui:ToggleSwitch Header="{l:Tr lblUseCustomTemplate}" IsOn="{Binding PathTemplateEnabled, Mode=TwoWay}" />

                            <StackPanel Visibility="{Binding TemplateFieldsVisible, Converter={StaticResource BoolToVis}}"
                                        Margin="0,4,0,4">
                                <StackPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource FieldLabel}" MinWidth="80" Text="{l:Tr lblFolderTemplate}" />
                                    <TextBox Text="{Binding FolderTemplate, UpdateSourceTrigger=PropertyChanged}"
                                             Width="430" FontFamily="Consolas" />
                                </StackPanel>
                                <StackPanel Style="{StaticResource Row}">
                                    <TextBlock Style="{StaticResource FieldLabel}" MinWidth="80" Text="{l:Tr lblFileTemplate}" />
                                    <TextBox Text="{Binding FileTemplate, UpdateSourceTrigger=PropertyChanged}"
                                             Width="430" FontFamily="Consolas" />
                                </StackPanel>
                                <TextBlock Foreground="#888" FontSize="12" Margin="90,2,0,0" TextWrapping="Wrap"
                                           Text="{}{artist} {albumartist} {album} {title} {titlefull} {year} {track} {track2} {disc} {genre} {counter}" />
                                <StackPanel Orientation="Horizontal" Margin="90,8,0,0">
                                    <TextBlock Text="{l:Tr lblPreview}" Foreground="#888" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding TemplatePreview}" Foreground="#1ED760" FontSize="12"
                                               FontFamily="Consolas" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </StackPanel>

                            <Border Height="1" Background="#18FFFFFF" Margin="0,8,0,10" />

                            <StackPanel IsEnabled="{Binding ClassicNamingEnabled}">
                                <ui:ToggleSwitch Header="{l:Tr lblAddFolders}" IsOn="{Binding AddFolders, Mode=TwoWay}" />
                                <ui:ToggleSwitch Header="{l:Tr lblAddSeparators}" IsOn="{Binding AddSeparators, Mode=TwoWay}" />
                                <ui:ToggleSwitch Header="{l:Tr lblCounterToFilePrefix}" IsOn="{Binding CounterToFilePrefix, Mode=TwoWay}" />
                                <ui:ToggleSwitch Header="{l:Tr lblAlbumTrackNumberToFilePrefix}" IsOn="{Binding AlbumTrackNumberPrefix, Mode=TwoWay}" />
                            </StackPanel>
                            <ui:ToggleSwitch Header="{l:Tr lblRecordOverRecordings}" IsOn="{Binding RecordOverRecordings, Mode=TwoWay}" />
                            <CheckBox Content="{l:Tr lblDuplicate}"
                                      IsChecked="{Binding DuplicateRecordings, Mode=TwoWay}"
                                      Visibility="{Binding DuplicateVisible, Converter={StaticResource BoolToVis}}"
                                      Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}" Text="{l:Tr lblRecorder}" />
                            <StackPanel Style="{StaticResource Row}"
                                        ToolTip="{l:Tr tipCounterDigits}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{l:Tr lblRecordingNum}" />
                                <Button Content="−" Command="{Binding NumMinusCommand}" Width="34" />
                                <TextBox Text="{Binding RecordingNumber, UpdateSourceTrigger=LostFocus}"
                                         Width="80" Margin="6,0,6,0" TextAlignment="Center" />
                                <Button Content="+" Command="{Binding NumPlusCommand}" Width="34" />
                            </StackPanel>

                            <StackPanel Style="{StaticResource Row}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{l:Tr lblRecordingTimer}" />
                                <TextBox Text="{Binding RecordingTimerText, UpdateSourceTrigger=LostFocus}"
                                         Width="110" ui:ControlHelper.PlaceholderText="HH:MM:SS" />
                                <TextBlock Text="{l:Tr lblBlankOff}" Foreground="#888" VerticalAlignment="Center" Margin="10,0,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ===================== ANALYZE ===================== -->
            <Grid x:Name="AnalyzePanel" Visibility="Collapsed"
                  AllowDrop="True" DragOver="Analyze_DragOver" DragLeave="Analyze_DragLeave" Drop="Analyze_Drop">

                <!-- Empty state: drop zone -->
                <Border x:Name="AnalyzeDropZone" CornerRadius="10" Background="#10FFFFFF"
                        BorderBrush="#33FFFFFF" BorderThickness="1.5" Margin="0,4,0,4">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ui:FontIcon Glyph="&#xEC4F;" FontSize="46" Foreground="#1ED760"
                                     HorizontalAlignment="Center" />
                        <TextBlock Text="{l:Tr anzDropTitle}" FontSize="18"
                                   Foreground="#EEEEEE" HorizontalAlignment="Center" Margin="0,16,0,4" />
                        <TextBlock Text="{l:Tr anzDropSubtitle}"
                                   Foreground="#888888" HorizontalAlignment="Center" Margin="0,0,0,20" />
                        <Button Click="Analyze_OpenFile_Click"
                                Padding="22,8" FontSize="14" HorizontalAlignment="Center"
                                Background="{StaticResource SpotifyGreenBrush}" Foreground="#000000"
                                BorderThickness="0" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Style="{StaticResource BtnIcon}" Glyph="&#xE8E5;" Foreground="#000000" />
                                <TextBlock Text="{l:Tr anzOpenFile}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Click="InfoButton_Click"
                                HorizontalAlignment="Center" Margin="0,18,0,0" Padding="6,2"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#1ED760" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Style="{StaticResource BtnIcon}" Glyph="&#xE946;" Foreground="#1ED760" />
                                <TextBlock Text="{l:Tr anzHowToRead}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Busy: custom equalizer-pulse loader (each bar animates its own transform) -->
                <StackPanel x:Name="AnalyzeBusy" Visibility="Collapsed"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Resources>
                        <Style TargetType="Border" x:Key="EqBar">
                            <Setter Property="Width" Value="9" />
                            <Setter Property="Height" Value="44" />
                            <Setter Property="CornerRadius" Value="4" />
                            <Setter Property="Margin" Value="4,0" />
                            <Setter Property="VerticalAlignment" Value="Bottom" />
                            <Setter Property="Background" Value="{StaticResource SpotifyGreenBrush}" />
                            <Setter Property="RenderTransformOrigin" Value="0.5,1" />
                            <Setter Property="RenderTransform">
                                <Setter.Value><ScaleTransform ScaleY="0.28" /></Setter.Value>
                            </Setter>
                        </Style>
                    </StackPanel.Resources>

                    <StackPanel Orientation="Horizontal" Height="48" HorizontalAlignment="Center">
                        <Border Style="{StaticResource EqBar}">
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             From="0.28" To="1" Duration="0:0:0.46" AutoReverse="True"
                                                             RepeatBehavior="Forever" BeginTime="0:0:0.00">
                                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                        </Border>
                        <Border Style="{StaticResource EqBar}">
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             From="0.28" To="1" Duration="0:0:0.46" AutoReverse="True"
                                                             RepeatBehavior="Forever" BeginTime="0:0:0.12">
                                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                        </Border>
                        <Border Style="{StaticResource EqBar}">
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             From="0.28" To="1" Duration="0:0:0.46" AutoReverse="True"
                                                             RepeatBehavior="Forever" BeginTime="0:0:0.24">
                                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                        </Border>
                        <Border Style="{StaticResource EqBar}">
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             From="0.28" To="1" Duration="0:0:0.46" AutoReverse="True"
                                                             RepeatBehavior="Forever" BeginTime="0:0:0.16">
                                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                        </Border>
                        <Border Style="{StaticResource EqBar}">
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             From="0.28" To="1" Duration="0:0:0.46" AutoReverse="True"
                                                             RepeatBehavior="Forever" BeginTime="0:0:0.06">
                                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="AnalyzeBusyPhase" Text="{l:Tr anzAnalyzing}" Foreground="#1DB954"
                               FontSize="16" Margin="0,20,0,0" HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Error -->
                <Border x:Name="AnalyzeError" Visibility="Collapsed" CornerRadius="8"
                        Background="#22FF5555" BorderBrush="#55FF5555" BorderThickness="1"
                        Padding="18" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="520">
                    <StackPanel>
                        <TextBlock x:Name="AnalyzeErrorText" Foreground="#FFD0D0" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" TextAlignment="Center" />
                        <Button Click="Analyze_OpenFile_Click"
                                Margin="0,14,0,0" HorizontalAlignment="Center" Padding="16,6">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Style="{StaticResource BtnIcon}" Glyph="&#xE8E5;" />
                                <TextBlock Text="{l:Tr anzTryAnother}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Results -->
                <ScrollViewer x:Name="AnalyzeResults" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock x:Name="AnalyzeFileName" FontSize="16" FontWeight="SemiBold"
                                           Foreground="#FFFFFF" TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="AnalyzeMeta" Foreground="#999999" Margin="0,2,0,0" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Orientation="Horizontal">
                                <Button Click="InfoButton_Click" Width="34" Height="34" Padding="0"
                                        VerticalAlignment="Top" Margin="0,0,10,0"
                                        ToolTip="{l:Tr anzHowToRead}">
                                    <ui:FontIcon Glyph="&#xE946;" FontSize="16" />
                                </Button>
                                <StackPanel>
                                    <Button Click="Analyze_OpenFile_Click"
                                            HorizontalAlignment="Right" Padding="14,6">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:FontIcon Style="{StaticResource BtnIcon}" Glyph="&#xE8E5;" />
                                            <TextBlock Text="{l:Tr anzOpenAnother}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <TextBlock Text="{l:Tr anzDragHint}" Foreground="#AAAAAA" FontSize="12.5"
                                               HorizontalAlignment="Right" Margin="0,7,14,0" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- Verdict -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionHeader}" Text="{l:Tr anzVerdictHeader}" />
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Grid x:Name="BadgeWrap" VerticalAlignment="Center" SizeChanged="BadgeWrap_SizeChanged">
                                        <!-- coloured ring behind the badge; inner badge is inset to reveal it -->
                                        <Border x:Name="BadgeRing" CornerRadius="16" />
                                        <Border x:Name="VerdictBadge" CornerRadius="14" Padding="14,5" Margin="3"
                                                Background="#1ED760">
                                            <TextBlock x:Name="VerdictTierText" Text="" FontWeight="Bold"
                                                       FontSize="14" Foreground="#000000" />
                                        </Border>
                                        <!-- lossless: a glowing comet + trailing falloff orbits the border (built in code) -->
                                        <Canvas x:Name="BadgeOrbit" IsHitTestVisible="False" ClipToBounds="False" />
                                    </Grid>
                                    <TextBlock x:Name="VerdictText" VerticalAlignment="Center" Margin="14,0,0,0"
                                               FontSize="15" Foreground="#FFFFFF" TextWrapping="Wrap" />
                                </StackPanel>
                                <TextBlock x:Name="VerdictDetail" Foreground="#BBBBBB" Margin="0,12,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!-- Waveform -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionHeader}" Text="{l:Tr anzWaveform}" />
                                <Border Background="#0CFFFFFF" CornerRadius="6" Padding="2">
                                    <Canvas x:Name="WaveformCanvas" Height="120" Background="Transparent"
                                            SizeChanged="WaveformCanvas_SizeChanged" ClipToBounds="True" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Frequency response & cut-off -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Style="{StaticResource SectionHeader}"
                                               Text="{l:Tr anzFreqResponse}" VerticalAlignment="Center" />
                                    <TextBlock x:Name="FreqResponseCutoffLabel" Foreground="#FFD54F"
                                               HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="SemiBold" />
                                </Grid>
                                <Grid Height="160" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="18" />
                                    </Grid.RowDefinitions>

                                    <Canvas x:Name="FreqDbAxis" Grid.Row="0" Grid.Column="0" />

                                    <Border Grid.Row="0" Grid.Column="1" CornerRadius="4" ClipToBounds="True"
                                            Background="#0CFFFFFF">
                                        <Canvas x:Name="FreqResponseCanvas" SizeChanged="FreqResponseCanvas_SizeChanged" />
                                    </Border>

                                    <Canvas x:Name="FreqHzAxis" Grid.Row="1" Grid.Column="1" Margin="0,2,0,0" />
                                </Grid>

                                <!-- explainer -->
                                <Border CornerRadius="6" Background="#14FFFFFF" BorderBrush="#26FFFFFF" BorderThickness="1"
                                        Padding="14,12" Margin="0,14,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ui:FontIcon Grid.Column="0" Glyph="&#xE946;" FontSize="16" Foreground="#1ED760"
                                                     VerticalAlignment="Top" Margin="0,2,12,0" />
                                        <TextBlock Grid.Column="1" Foreground="#DCDCDC" TextWrapping="Wrap"
                                                   FontSize="13" LineHeight="21"
                                                   Text="{l:Tr anzFreqExplainer}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Spectrogram -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Style="{StaticResource SectionHeader}"
                                               Text="{l:Tr anzSpectrogram}" VerticalAlignment="Center" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                                        <TextBlock Text="{l:Tr anzHeatmapTheme}" Foreground="#D8D8D8"
                                                   VerticalAlignment="Center" Margin="0,0,12,0" FontSize="15" />
                                        <ComboBox x:Name="PaletteCombo" Width="120"
                                                  VerticalAlignment="Center" FontSize="14"
                                                  SelectionChanged="PaletteCombo_SelectionChanged">
                                            <ComboBoxItem Content="Inferno" IsSelected="True" />
                                            <ComboBoxItem Content="Magma" />
                                            <ComboBoxItem Content="Viridis" />
                                            <ComboBoxItem Content="Heat" />
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                                <Grid Height="500" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="56" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="18" />
                                    </Grid.RowDefinitions>

                                    <!-- frequency axis -->
                                    <Canvas x:Name="SpecFreqAxis" Grid.Row="0" Grid.Column="0" />

                                    <!-- heatmap + overlay (cut-off line) -->
                                    <Border Grid.Row="0" Grid.Column="1" CornerRadius="4" ClipToBounds="True"
                                            Background="#000000">
                                        <Grid>
                                            <Image x:Name="SpectrogramImageControl" Stretch="Fill"
                                                   RenderOptions.BitmapScalingMode="Linear" />
                                            <Canvas x:Name="SpecOverlay" SizeChanged="SpecOverlay_SizeChanged" />
                                        </Grid>
                                    </Border>

                                    <!-- dB colour legend -->
                                    <Grid Grid.Row="0" Grid.Column="2" Margin="10,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="14" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Rectangle x:Name="LegendRect" Grid.Column="0" RadiusX="2" RadiusY="2" />
                                        <Grid Grid.Column="1" Margin="4,0,0,0">
                                            <TextBlock Text="0 dB" VerticalAlignment="Top" FontSize="10" Foreground="#999999" />
                                            <TextBlock Text="-60" VerticalAlignment="Center" FontSize="10" Foreground="#999999" />
                                            <TextBlock Text="-120" VerticalAlignment="Bottom" FontSize="10" Foreground="#999999" />
                                        </Grid>
                                    </Grid>

                                    <!-- time axis (under heatmap) -->
                                    <Canvas x:Name="SpecTimeAxis" Grid.Row="1" Grid.Column="1" Margin="0,2,0,0" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Drag-over highlight (shown while a file is dragged over the pane) -->
                <Border x:Name="AnalyzeDragOverlay" Visibility="Collapsed" IsHitTestVisible="False"
                        Panel.ZIndex="20" CornerRadius="10" Background="#D40A0A0A"
                        BorderBrush="{StaticResource SpotifyGreenBrush}" BorderThickness="2">
                    <Border.Effect>
                        <DropShadowEffect Color="#1ED760" ShadowDepth="0" BlurRadius="26" Opacity="0.55" />
                    </Border.Effect>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ui:FontIcon Glyph="&#xE896;" FontSize="46" Foreground="#1ED760" HorizontalAlignment="Center" />
                        <TextBlock Text="{l:Tr anzDropToAnalyze}" FontSize="20" Foreground="#FFFFFF"
                                   Margin="0,14,0,0" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Info modal: how to read the analysis -->
                <Grid x:Name="InfoOverlay" Visibility="Collapsed" Panel.ZIndex="30" Background="#B3000000"
                      MouseLeftButtonDown="InfoOverlay_BackdropClick">
                    <Border MaxWidth="680" MaxHeight="620" Margin="24" VerticalAlignment="Center"
                            Background="#1C1C1C" CornerRadius="12" BorderBrush="#33FFFFFF" BorderThickness="1"
                            MouseLeftButtonDown="InfoCard_Click">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="22,18,12,10">
                                <StackPanel Orientation="Horizontal">
                                    <ui:FontIcon Glyph="&#xE946;" FontSize="18" Foreground="#1ED760" VerticalAlignment="Center" />
                                    <TextBlock Text="{l:Tr anzInfoTitle}" FontSize="18" FontWeight="SemiBold"
                                               Foreground="#FFFFFF" Margin="10,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                                <Button Click="InfoClose_Click" HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Width="30" Height="30" Padding="0" ToolTip="{l:Tr lblClose}">
                                    <ui:FontIcon Glyph="&#xE711;" FontSize="13" />
                                </Button>
                            </Grid>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="22,0,22,20">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionHeader}" Text="{l:Tr anzInfoVerdictHdr}" />
                                    <TextBlock Foreground="#CCCCCC" TextWrapping="Wrap" FontSize="13" LineHeight="20" Margin="0,0,0,16"
                                               Text="{l:Tr anzInfoVerdictBody}" />

                                    <TextBlock Style="{StaticResource SectionHeader}" Text="{l:Tr anzWaveform}" />
                                    <TextBlock Foreground="#CCCCCC" TextWrapping="Wrap" FontSize="13" LineHeight="20" Margin="0,0,0,16"
                                               Text="{l:Tr anzInfoWaveformBody}" />

                                    <TextBlock Style="{StaticResource SectionHeader}" Text="{l:Tr anzFreqResponse}" />
                                    <TextBlock Foreground="#CCCCCC" TextWrapping="Wrap" FontSize="13" LineHeight="20" Margin="0,0,0,8"
                                               Text="{l:Tr anzInfoFreqBody}" />
                                    <Border Background="#14FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="6"
                                            Padding="14,10" Margin="0,0,0,8">
                                        <TextBlock Foreground="#DCDCDC" FontSize="13" LineHeight="21"
                                                   Text="{l:Tr anzInfoFreqBox}" />
                                    </Border>
                                    <TextBlock Foreground="#CCCCCC" TextWrapping="Wrap" FontSize="13" LineHeight="20" Margin="0,0,0,16"
                                               Text="{l:Tr anzInfoFreqAfter}" />

                                    <TextBlock Style="{StaticResource SectionHeader}" Text="{l:Tr anzSpectrogram}" />
                                    <TextBlock Foreground="#CCCCCC" TextWrapping="Wrap" FontSize="13" LineHeight="20" Margin="0,0,0,16"
                                               Text="{l:Tr anzInfoSpectroBody}" />

                                    <TextBlock Style="{StaticResource SectionHeader}" Text="{l:Tr anzInfoGoodHdr}" />
                                    <TextBlock Foreground="#CCCCCC" TextWrapping="Wrap" FontSize="13" LineHeight="20" Margin="0,0,0,4"
                                               Text="{l:Tr anzInfoGoodBody}" />
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

        </Grid>
    </ui:NavigationView>
</Window>
