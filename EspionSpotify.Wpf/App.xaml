<Application x:Class="EspionSpotify.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemeResources RequestedTheme="Dark" />
                <ui:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>

            <!-- Spotify-style accent -->
            <Color x:Key="SpotifyGreen">#1ED760</Color>
            <SolidColorBrush x:Key="SpotifyGreenBrush" Color="{StaticResource SpotifyGreen}" />

            <!-- Slightly rounder controls across the app (buttons, text boxes, combos). -->
            <CornerRadius x:Key="ControlCornerRadius">6</CornerRadius>

            <!-- Consistent buttons: rounded + a smooth hover/press overlay that darkens the button's own
                 colour (30% black wash on hover, deeper on press), so green accent buttons and default
                 buttons both feel right. Based on ModernWpf's default style, so the window caption
                 buttons and other framework buttons keep their own styles. -->
            <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Padding" Value="12,5,12,6" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Border x:Name="Bg" CornerRadius="{DynamicResource ControlCornerRadius}"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}" />
                                <Border x:Name="Overlay" CornerRadius="{DynamicResource ControlCornerRadius}"
                                        Background="Black" Opacity="0" />
                                <ContentPresenter x:Name="cp" Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"
                                                  RecognizesAccessKey="True" />
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Overlay" Storyboard.TargetProperty="Opacity"
                                                                 To="0.3" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Overlay" Storyboard.TargetProperty="Opacity"
                                                                 To="0" Duration="0:0:0.22">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <!-- Press: darken further, then settle back to the hover level. -->
                                <Trigger Property="IsPressed" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Overlay" Storyboard.TargetProperty="Opacity"
                                                                 To="0.45" Duration="0:0:0.06" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Overlay" Storyboard.TargetProperty="Opacity"
                                                                 To="0.3" Duration="0:0:0.12" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.45" />
                                    <Setter TargetName="cp" Property="Opacity" Value="0.45" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Icon toggle (e.g. the show/hide eye): matches the button style (rounded + darken-on-hover
                 fade) and tints green when active/checked. -->
            <Style x:Key="IconToggleButton" TargetType="ToggleButton">
                <Setter Property="Background" Value="#16FFFFFF" />
                <Setter Property="Foreground" Value="#DDDDDD" />
                <Setter Property="BorderBrush" Value="#33FFFFFF" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Height" Value="34" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Grid>
                                <Border x:Name="Bg" CornerRadius="{DynamicResource ControlCornerRadius}"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" />
                                <Border x:Name="Tint" CornerRadius="{DynamicResource ControlCornerRadius}"
                                        Background="{StaticResource SpotifyGreenBrush}" Opacity="0" />
                                <Border x:Name="Overlay" CornerRadius="{DynamicResource ControlCornerRadius}" Background="Black" Opacity="0" />
                                <ContentPresenter x:Name="cp" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Tint" Property="Opacity" Value="0.9" />
                                    <Setter TargetName="cp" Property="TextElement.Foreground" Value="#000000" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Overlay" Storyboard.TargetProperty="Opacity" To="0.25" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Overlay" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.22">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Overlay" Storyboard.TargetProperty="Opacity" To="0.4" Duration="0:0:0.06" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Overlay" Storyboard.TargetProperty="Opacity" To="0.25" Duration="0:0:0.12" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.45" />
                                    <Setter TargetName="cp" Property="Opacity" Value="0.45" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ComboBox: bigger and rounder, keeping ModernWpf's animated dropdown popup. -->
            <Style TargetType="ComboBox" BasedOn="{StaticResource DefaultComboBoxStyle}">
                <Setter Property="MinHeight" Value="36" />
                <Setter Property="Padding" Value="12,6,10,6" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <!-- ToggleSwitch: keep ModernWpf's own switch (animated green pill, click-to-toggle wired up)
                 and just scale it up a touch so it reads bigger and more modern. -->
            <Style TargetType="ui:ToggleSwitch" BasedOn="{StaticResource {x:Type ui:ToggleSwitch}}">
                <Setter Property="Margin" Value="0,5,0,5" />
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="FontSize" Value="15" />
            </Style>

            <!-- CheckBox: rounded box that fills green with a checkmark that springs in. -->
            <Style TargetType="CheckBox">
                <Setter Property="Foreground" Value="#E6E6E6" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Margin" Value="0,6,0,6" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <StackPanel Orientation="Horizontal" Background="Transparent">
                                <Grid Width="24" Height="24" VerticalAlignment="Center">
                                    <Border CornerRadius="6" Background="#22FFFFFF" BorderBrush="#66FFFFFF" BorderThickness="1.5" />
                                    <Border x:Name="BoxOn" CornerRadius="6" Background="{StaticResource SpotifyGreenBrush}" Opacity="0" />
                                    <Path x:Name="Check" Data="M6,12 L10.5,16.5 L18,7" Stroke="Black" StrokeThickness="2.4"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                          Stretch="None" Opacity="0" RenderTransformOrigin="0.5,0.5">
                                        <Path.RenderTransform><ScaleTransform x:Name="CheckS" ScaleX="0.4" ScaleY="0.4" /></Path.RenderTransform>
                                    </Path>
                                </Grid>
                                <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="BoxOn" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12" />
                                                <DoubleAnimation Storyboard.TargetName="Check" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12" />
                                                <DoubleAnimation Storyboard.TargetName="CheckS" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.22">
                                                    <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.7" /></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="CheckS" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.22">
                                                    <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.7" /></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="BoxOn" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12" />
                                                <DoubleAnimation Storyboard.TargetName="Check" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.1" />
                                                <DoubleAnimation Storyboard.TargetName="CheckS" Storyboard.TargetProperty="ScaleX" To="0.4" Duration="0:0:0.1" />
                                                <DoubleAnimation Storyboard.TargetName="CheckS" Storyboard.TargetProperty="ScaleY" To="0.4" Duration="0:0:0.1" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
